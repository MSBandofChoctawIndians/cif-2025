---
import "../styles/global.css";
import Nav from "../components/Nav.jsx";
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="We invite you to join us for the Choctaw Indian Fair.
        The fair takes place on our centuries-old homeland in beautiful Choctaw, Mississippi."
    />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
